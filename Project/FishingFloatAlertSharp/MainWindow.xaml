<Window x:Class="FishingFloatAlertSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishingFloatAlertSharp"
        mc:Ignorable="d"
        Title="찌 알리미"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource AppForegroundBrush}"
        Loaded="MainWindow_OnLoaded"
        Closing="MainWindow_OnClosing">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0"
              Margin="12,10,12,0"
              VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <TextBlock Text="카메라: "
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="CameraCombo"
                          MinWidth="320"
                          Height="24"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          DisplayMemberPath="Name"
                          SelectionChanged="CameraCombo_OnSelectionChanged"/>
                <Button x:Name="RefreshCamerasButton"
                        Width="24"
                        Height="24"
                        Padding="0"
                        FontFamily="Segoe MDL2 Assets"
                        Content="&#xE72C;"
                        FontSize="11"
                        Foreground="Black"
                        ToolTip="카메라 목록 새로고침"
                        VerticalAlignment="Center"
                        Click="RefreshCamerasButton_OnClick"/>
            </StackPanel>
            <TextBlock x:Name="ClockTextBlock"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       FontFamily="Consolas"
                       FontSize="14"
                       Text=""/>
        </Grid>
        <Border Grid.Row="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="12,10,12,12"
                Width="1280"
                Height="720"
                Background="#FF101010"
                BorderBrush="#FF404040"
                BorderThickness="1"
                ClipToBounds="True">
            <Image x:Name="PreviewImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="Fant"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"/>
        </Border>
    </Grid>
</Window>
