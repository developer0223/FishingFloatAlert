<Window x:Class="FishingFloatAlertSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishingFloatAlertSharp"
        mc:Ignorable="d"
        Title="찌 알리미"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource AppForegroundBrush}"
        Loaded="MainWindow_OnLoaded">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="12,10,12,0">
            <TextBlock Text="카메라: "
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <ComboBox x:Name="CameraCombo"
                      MinWidth="320"
                      Height="24"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      DisplayMemberPath="Name"
                      SelectionChanged="CameraCombo_OnSelectionChanged"/>
            <Button x:Name="RefreshCamerasButton"
                    Width="24"
                    Height="24"
                    Padding="0"
                    FontFamily="Segoe MDL2 Assets"
                    Content="&#xE72C;"
                    FontSize="11"
                    Foreground="Black"
                    ToolTip="카메라 목록 새로고침"
                    VerticalAlignment="Center"
                    Click="RefreshCamerasButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
