<Window x:Class="FishingFloatAlertSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishingFloatAlertSharp"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="찌 알리미"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource AppForegroundBrush}"
        Loaded="MainWindow_OnLoaded"
        Closing="MainWindow_OnClosing"
        Deactivated="MainWindow_OnDeactivated"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown"
        PreviewKeyUp="MainWindow_OnPreviewKeyUp">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0"
              Margin="12,10,12,0"
              VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <TextBlock Text="카메라: "
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="CameraDeviceComboBox"
                          MinWidth="320"
                          Height="24"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          DisplayMemberPath="Name"
                          SelectionChanged="CameraDeviceComboBox_OnSelectionChanged"/>
                <Button x:Name="RefreshCamerasButton"
                        Width="24"
                        Height="24"
                        Padding="0"
                        FontFamily="Segoe MDL2 Assets"
                        Content="&#xE72C;"
                        FontSize="11"
                        Foreground="Black"
                        ToolTip="카메라 목록 새로고침"
                        VerticalAlignment="Center"
                        Click="RefreshCamerasButton_OnClick"/>
            </StackPanel>
            <TextBlock x:Name="ClockTextBlock"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       FontFamily="Consolas"
                       FontSize="14"
                       Text=""/>
        </Grid>
        <Grid Grid.Row="1"
              Margin="12,10,12,12"
              HorizontalAlignment="Left"
              VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,8"
                        VerticalAlignment="Center">
                <RadioButton x:Name="PreviewViewRawRadio"
                             Content="원본 (RAW)"
                             GroupName="PreviewView"
                             IsChecked="True"
                             Margin="0,0,16,0"
                             VerticalAlignment="Center"
                             Foreground="White"
                             Checked="PreviewViewModeRadio_OnChecked"/>
                <RadioButton x:Name="PreviewViewMaskRadio"
                             Content="색상 마스크"
                             GroupName="PreviewView"
                             VerticalAlignment="Center"
                             Foreground="White"
                             Checked="PreviewViewModeRadio_OnChecked"/>
            </StackPanel>
            <Border Grid.Row="1"
                    Width="1280"
                    Height="720"
                    Background="#FF101010"
                    BorderBrush="#FF404040"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid>
                <Image x:Name="PreviewImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="Fant"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>
                <Canvas x:Name="RoiOverlayCanvas"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        SizeChanged="RoiOverlayCanvas_OnSizeChanged"
                        MouseLeftButtonDown="RoiOverlayCanvas_OnMouseLeftButtonDown"
                        MouseMove="RoiOverlayCanvas_OnMouseMove"
                        MouseLeftButtonUp="RoiOverlayCanvas_OnMouseLeftButtonUp"
                        LostMouseCapture="RoiOverlayCanvas_OnLostMouseCapture">
                    <Rectangle x:Name="PreviewRoiRectangle"
                               Stroke="#FFFFCC44"
                               StrokeThickness="2"
                               Fill="#26FFCC44"
                               IsHitTestVisible="False"/>
                </Canvas>
                </Grid>
            </Border>
        </Grid>
        <Border Grid.Row="2"
                Margin="12,0,12,12"
                Padding="14,12"
                HorizontalAlignment="Stretch"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="#FF404040"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Margin="0,0,12,0">
                    <TextBlock Text="타겟 컬러"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <xctk:ColorPicker x:Name="TargetColorPickerControl"
                                          Width="240"
                                          Height="28"
                                          ShowRecentColors="False"
                                          ShowStandardColors="True"
                                          SelectedColorChanged="TargetColorPickerControl_OnSelectedColorChanged"/>
                        <ToggleButton x:Name="EyedropperToggleButton"
                                      Margin="8,0,0,0"
                                      Width="32"
                                      Height="28"
                                      Padding="0"
                                      FontFamily="Segoe MDL2 Assets"
                                      Content="&#xEF3C;"
                                      Foreground="{StaticResource AppForegroundBrush}"
                                      ToolTip="스포이드: 켠 뒤 미리보기 영상을 클릭하면 해당 픽셀 색으로 설정됩니다."
                                      Checked="EyedropperToggleButton_OnChecked"
                                      Unchecked="EyedropperToggleButton_OnUnchecked"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="색상 허용치"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="RGB 각 채널에서 타겟과 허용할 최대 차이 (비슷한 색 포함)"
                               TextWrapping="Wrap"
                               Foreground="#FFB0B0B0"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Slider x:Name="ColorToleranceSlider"
                                Width="160"
                                Minimum="0"
                                Maximum="50"
                                Value="12"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="ColorToleranceSlider_OnValueChanged"/>
                        <TextBlock x:Name="ColorToleranceValueText"
                                   Text="12"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   MinWidth="28"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
